first_word = input("What is your first word? ")
sec_word = input("What is your second word? ")

def has_more_letters(let1: str, let2: str) -> str:
    length1 = len(let1)  # get the length of the first word
    length2 = len(let2)  # get the length of the second word

    if length1 > length2:
        return let1
    elif length1 < length2:
        return let2
    
longest_word = has_more_letters(first_word, sec_word)

print(f"{longest_word} is the longest word.")